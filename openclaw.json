{
  "gateway": {
    "port": 8080,
    "bind": "lan",
    "controlUi": {
      "allowedOrigins": [
        "https://openclaw-fv5c.onrender.com"
      ],
      "allowInsecureAuth": true
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "streaming": "partial"
    },
    "whatsapp": {
      "enabled": true,
      "dmPolicy": "pairing"
    }
  },
  "tools": {
    "exec": { 
      "enabled": true,
      "approval": "manual" 
    },
    "file_write": { "enabled": true },
    "media": {
      "audio": {
        "enabled": true,
        "models": [
          {
            "provider": "openai",
            "model": "whisper-1"
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "workDir": "/data/openclaw-workspace",
      "model": {
        "primary": "openai/gpt-4o"
      }
    }
  }
}
