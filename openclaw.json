{
  "gateway": {
    "port": 8080,
    "bind": "lan",
    "controlUi": {
      "allowedOrigins": [
        "https://openclaw-fv5c.onrender.com"
      ],
      "allowInsecureAuth": true
    }
  },
  "channels": {
