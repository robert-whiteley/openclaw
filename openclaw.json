{
  "gateway": {
    "port": 8080,
    "mode": "local",
    "bind": "lan",
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "controlUi": {
      "allowedOrigins": ["https://openclaw-fv5c.onrender.com"],
      "allowInsecureAuth": false
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "streaming": "partial"
    },
    "whatsapp": {
      "enabled": true,
      "dmPolicy": "pairing"
    }
  },
  "tools": {
    "exec": {
      "ask": "always"
    },
    "media": {
      "audio": {
        "enabled": true,
        "models": [
          {
            "provider": "openai",
            "model": "whisper-1"
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "workspace": "/data/openclaw-workspace",
      "model": {
        "primary": "openai/gpt-4.1-mini"
      },
      "memorySearch": {
        "enabled": false
      }
    }
  }
}
